<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="true">
        <shape android:shape="rectangle">
            <corners android:radius="100dp"/>
            <gradient android:startColor="#f2c745" android:endColor="#ff335d" android:angle="0" android:type="linear" android:centerColor="#fa6f49" android:startX="-0.08" android:startY="1" android:endX="1" android:endY="0.07"/>
            <stroke android:width="0.5dp" android:color="#33ffffff"/>
        </shape>
    </item>
    <item android:state_enabled="false">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="100dp"/>
                    <gradient android:startColor="#f2c745" android:endColor="#ff335d" android:angle="0" android:type="linear" android:centerColor="#fa6f49" android:startX="-0.08" android:startY="1" android:endX="1" android:endY="0.07"/>
                    <stroke android:width="0.5dp" android:color="#33ffffff"/>
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#66000000"/>
                    <corners android:radius="100dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
