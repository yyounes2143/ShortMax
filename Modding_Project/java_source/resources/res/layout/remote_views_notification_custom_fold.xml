<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
    <LinearLayout android:orientation="vertical" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="12dp">
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:ellipsize="end" android:id="@+id/title_tv" android:layout_width="match_parent" android:layout_height="wrap_content" android:maxLines="1" style="@style/Notification.Title"/>
        </LinearLayout>
        <TextView android:ellipsize="end" android:id="@+id/content_tv" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:maxLines="2" android:includeFontPadding="false" style="@style/Notification.Content"/>
    </LinearLayout>
    <ImageView android:layout_gravity="center_vertical" android:id="@+id/custom_icon" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ntf_erpiring_icon" android:importantForAccessibility="no" android:layout_marginEnd="2dp"/>
</LinearLayout>
