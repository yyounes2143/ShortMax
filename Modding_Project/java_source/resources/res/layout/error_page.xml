    <ImageView android:id="@+id/imageView" android:visibility="visible" android:layout_width="50sp" android:layout_height="50sp" android:src="@drawable/no_wifi"/>
    <TextView android:textSize="22sp" android:textStyle="bold" android:textColor="#000000" android:id="@+id/textView" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="15dp" android:text="Oops, you`re offline!"/>
