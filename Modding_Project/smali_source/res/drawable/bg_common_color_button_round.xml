<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="true">
        <shape android:shape="rectangle">
            <corners android:radius="100.0dip" />
            <gradient android:startColor="#fff2c745" android:endColor="#ffff335d" android:angle="0.0" android:type="linear" android:centerColor="#fffa6f49" android:startX="-0.08" android:startY="1.0" android:endX="1.0" android:endY="0.07" />
            <stroke android:width="0.5dip" android:color="#33ffffff" />
        </shape>
    </item>
    <item android:state_enabled="false">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="100.0dip" />
                    <gradient android:startColor="#fff2c745" android:endColor="#ffff335d" android:angle="0.0" android:type="linear" android:centerColor="#fffa6f49" android:startX="-0.08" android:startY="1.0" android:endX="1.0" android:endY="0.07" />
                    <stroke android:width="0.5dip" android:color="#33ffffff" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#66000000" />
                    <corners android:radius="100.0dip" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
